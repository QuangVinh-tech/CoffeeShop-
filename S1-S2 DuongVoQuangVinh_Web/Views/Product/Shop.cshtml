@model IEnumerable<S1_S2_DuongVoQuangVinh__Web__.Models.Product>

<h2>Danh sách sản phẩm</h2>

<table class="table">
    <tr>
        <th>Tên</th>
        <th>Giá</th>
        <th>Chi tiết</th>
        <th>Ảnh</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.Detail</td>
            <td>
                <img src="@item.ImageUrl" width="100" />
            </td>
        </tr>
    }
</table>